@model SFA.DAS.ProviderCommitments.Web.Models.Cohort.SelectAddDraftApprenticeshipJourneyViewModel

@{
    ViewBag.Title = "How many learners would you like to add?";
    ViewBag.ZendeskLabel = "add-how-many-learners";
    ViewBag.GaData.Vpv = "/unapproved/add/how-many-learners";
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <partial name="_ValidationSummary" />
        <form method="post">
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.ProviderId)
            <div class="govuk-form-group @(ViewContext.ModelState.IsValid ? "" : "govuk-form-group--error")">
                <fieldset class="govuk-fieldset">
                    <legend class="govuk-fieldset__legend govuk-fieldset__legend--xl">
                        <h1 class="govuk-fieldset__heading">
                            How many learners would you like to add?
                        </h1>
                    </legend>
                    @Html.ValidationMessageFor(m => m.Selection, null, new { @class = "govuk-error-message", id = "error-message-" + Html.IdFor(m => m.Selection) })
                    <div class="govuk-radios">
                        <div class="govuk-radios__item">
                            <input asp-for="Selection" value="Single" type="radio" class="govuk-radios__input" id="confirm-Single" />
                            <label class="govuk-label govuk-radios__label" for="confirm-Single">
                                1 learner at a time
                            </label>
                            <div id="single-select-hint" class="govuk-hint govuk-radios__hint">
                                New or existing cohorts
                                Auto reservations or existing reservations
                            </div>
                        </div>
                        <div class="govuk-radios__item">
                            <input asp-for="Selection" value="Multiple" type="radio" class="govuk-radios__input" id="confirm-Multiple" />
                            <label class="govuk-label govuk-radios__label" for="confirm-Multiple">
                                2 or more learners at once
                            </label>
                            <div id="multiple-select-hint" class="govuk-hint govuk-radios__hint">
                                New cohorts only
                                Auto reservations only
                            </div>
                        </div>
                    </div>
                </fieldset>
            </div>
            <button class="govuk-button" type="submit" data-module="govuk-button">
                Continue
            </button>
        </form>
    </div>
</div>

@section breadcrumb
{
    <a id="back-link" class="govuk-back-link" href=@Url.Action("SelectDraftApprenticeshipsEntryMethod", new { Model.ProviderId })>Back</a>
}